# Configurações do ambiente - Copie para .env e configure conforme necessário
# Valores: development, production
ENVIRONMENT=development

# Configurações do banco MySQL (necessário apenas para produção)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha_aqui
MYSQL_DATABASE=intellexia
DATABASE_TYPE=mysql

# Chave secreta (ALTERE em produção!)
SECRET_KEY=your-secret-key-change-in-production
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Modelos LLM por tier (usados como padrão em todos os agentes)
# DEFAULT_MODEL      → tarefas pesadas: geração de petições, recursos
# DEFAULT_MODEL_MINI → tarefas médias: análise, extração, classificação, queries
# DEFAULT_MODEL_NANO → tarefas leves: roteamento, keywords, metadados
# DEFAULT_MODEL_ROBUST → tarefas críticas que exigem maior qualidade de raciocínio e síntese
# DEFAULT_MODEL_LEGAL_DRAFTING → geração de documentos jurídicos (impugnação, manifestação, petição)
DEFAULT_MODEL=openai/gpt-5.4-mini
DEFAULT_MODEL_MINI=openai/gpt-5.4-mini
DEFAULT_MODEL_NANO=openai/gpt-5.4-nano
DEFAULT_MODEL_ROBUST=openai/gpt-5.4
DEFAULT_MODEL_LEGAL_DRAFTING=openai/gpt-5.4
FAP_CLASSIFIER_MODEL=openai/gpt-5-mini


# Overrides por agente (opcional — sobrepõem os defaults acima)
KB_QUERY_MODEL=
KB_ROUTER_MODEL=
QUERY_MODEL=
QUERY_ENHANCER_MODEL=
FAP_CLASSIFIER_MODEL=

MEILISEARCH_API_KEY=your-meilisearch-api-key-change-in-production

OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
VECTOR_SIZE=1536
EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────────────────────────────────────
# Envio de e-mail (SMTP) — notificações em Configurações → Notificações
# ──────────────────────────────────────────────────────────────────────────────
# Sem SMTP_HOST/SMTP_FROM_EMAIL nenhuma notificação é enviada (o sistema apenas avisa).
SMTP_HOST=
SMTP_PORT=587                      # 465 = SSL direto; demais portas usam STARTTLS
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=nao-responda@seudominio.com.br
SMTP_FROM_NAME=IntellexIA
SMTP_USE_TLS=1                     # '0' desativa o STARTTLS (relay interno sem TLS)
SMTP_TIMEOUT=30

# Domínio público DESTA instalação (dev e produção são diferentes!). É a ÚNICA
# variável de domínio que precisa ser definida — daqui saem:
#   - os links dos e-mails do cron (que roda sem requisição e não descobre sozinho);
#   - o endereço que o servidor MCP anuncia no OAuth (este + "/mcp");
#   - o domínio usado pelo deploy/deploy_mcp.sh.
# Nas telas (modal do conector, manual) a URL vem do domínio acessado, então elas
# funcionam mesmo com isto em branco.
APP_PUBLIC_URL=

# ──────────────────────────────────────────────────────────────────────────────
# MCP Server (mcp_server/server.py)
# ──────────────────────────────────────────────────────────────────────────────
# Transport: streamable-http (padrão) | stdio (para clientes locais sem HTTP)
MCP_TRANSPORT=streamable-http

# Host e porta — usados apenas quando MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8001

# Token de autenticação Bearer — obrigatório em produção (streamable-http)
# Gere um token seguro: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

# Endereço público do MCP. Só defina se ele viver em outro domínio/subdomínio que o
# app (ex.: https://mcp.seudominio.com.br/mcp). Em branco, sai de APP_PUBLIC_URL + "/mcp".
MCP_PUBLIC_URL=