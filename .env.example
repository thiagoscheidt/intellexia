# Configurações do ambiente - Copie para .env e configure conforme necessário
# Valores: development, production
ENVIRONMENT=development

# Configurações do banco MySQL (necessário apenas para produção)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha_aqui
MYSQL_DATABASE=intellexia
DATABASE_TYPE=mysql

# Chave secreta (ALTERE em produção!)
SECRET_KEY=your-secret-key-change-in-production
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Modelos LLM por tier (usados como padrão em todos os agentes)
# DEFAULT_MODEL      → tarefas pesadas: geração de petições, recursos
# DEFAULT_MODEL_MINI → tarefas médias: análise, extração, classificação, queries
# DEFAULT_MODEL_NANO → tarefas leves: roteamento, keywords, metadados
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_MODEL_MINI=gpt-4o-mini
DEFAULT_MODEL_NANO=gpt-4o-mini
FAP_CLASSIFIER_MODEL=openai/gpt-5-mini


# Overrides por agente (opcional — sobrepõem os defaults acima)
KB_QUERY_MODEL=
KB_ROUTER_MODEL=
QUERY_MODEL=
QUERY_ENHANCER_MODEL=
FAP_CLASSIFIER_MODEL=

MEILISEARCH_API_KEY=your-meilisearch-api-key-change-in-production

OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
VECTOR_SIZE=1536
EMBEDDING_MODEL=text-embedding-3-small